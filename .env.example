# Session secret (required in production: at least 32 random characters)
SESSION_SECRET=your_random_session_secret_at_least_32_chars

# Encrypt Whop API keys and webhook secrets at rest (required in production)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# MySQL (required for multi-user mode)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=whop_admin

# Production security (recommended)
NODE_ENV=production
COOKIE_SECURE=true
APP_BASE_URL=https://yourdomain.com

# Public sign-up: disabled by default in production. Set true to allow /signup
# ALLOW_REGISTRATION=false

# Admin bootstrap: set email and explicitly allow promotion on login/signup
# ADMIN_EMAIL=admin@example.com
# ALLOW_ADMIN_EMAIL_PROMOTION=true

# Shared Whop env fallback: OFF in production. Dev only if you set both:
# ALLOW_SHARED_WHOP_ENV=true
# WHOP_API_KEY=apik_xxx
# WHOP_PARENT_COMPANY_ID=biz_xxx

# Optional
# PORT=3001
