# Session secret (random string for signing cookies)
SESSION_SECRET=your_random_session_secret_here

# MySQL (required for multi-user mode)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=whop_admin

# Optional: base URL for webhook links in Settings (e.g. https://yourdomain.com)
# APP_BASE_URL=https://yourdomain.com

# Optional: first admin – set to an email to grant admin role on login/signup (e.g. admin@example.com)
# ADMIN_EMAIL=admin@example.com

# Optional
# PORT=3001
